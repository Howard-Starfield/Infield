    "@tauri-apps/plugin-store": "~2.4.1",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/p5": "^1.7.7",
    "canvas-confetti": "^1.9.4",
    "codemirror": "^6.0.1",
    "hyperformula": "2.7.1",
    "i18next": "^25.7.2",
    "immer": "^11.1.3",
    "lucide-react": "^0.542.0",
    "motion": "^12.38.0",
    "p5": "^2.2.3",
    "react": "19.1.1",
    "react-dom": "19.1.1",
