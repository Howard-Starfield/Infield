    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-select": "^5.0.1",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.4",
